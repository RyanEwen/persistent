node_modules/
dist/
.vite/
*.tsbuildinfo

# Local env / secrets
.env
.env.*.local
.secrets/

# Firebase credentials — never commit (server creds + APK client config live in
# .secrets/; CI injects google-services.json from the GOOGLE_SERVICES_JSON secret)
*firebase-adminsdk*.json
google-services.json

# Runtime data / scratch (root only — must not match apps/web/src/data)
/data/
tmp/
.backups/

# Logs
*.log
npm-debug.log*

# OS / editor
.DS_Store
Thumbs.db

# Capacitor native projects — generated by `cap add` + scripts/setup-android.mjs
# (see apps/mobile/README.md), never committed. Regenerate with prepare:android.
apps/mobile/android/
apps/mobile/ios/
apps/mobile/dist/

# Test output
coverage/

# Android release keystore (kept out of git; CI uses the base64 secret)
apps/mobile/release.keystore
*.keystore
