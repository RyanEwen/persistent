# One env file for everything (gitignored). Copy to .env and fill in.
#
# - Local dev (devcontainer): DATABASE_URL + API_PORT are injected by
#   devcontainer.json, so most values are optional; DEMO_MODE=true lets auth work
#   without mail infra.
# - Production (compose.server.yml on the server): set POSTGRES_PASSWORD,
#   CLIENT_ORIGIN, the Cloudflare email vars, and VAPID. Compose auto-loads .env,
#   builds DATABASE_URL from POSTGRES_*, and forces DEMO_MODE=false.
# - Running `npm run deploy:prod` from your machine: set the DEPLOY_* target.

# --- Database ---
# Production: the compose `db` service is created from these.
POSTGRES_DB=persistent
POSTGRES_USER=postgres
POSTGRES_PASSWORD=change-me-strong
# Local dev: the devcontainer's `db` service provides DATABASE_URL automatically;
# override only if needed.
# DATABASE_URL=postgresql://postgres:postgres@db:5432/persistent?schema=public

# --- API ---
API_PORT=4000
# Public URL (CORS + secure-cookie detection).
# Prod example: https://persistent.dynamic-solutions.ca
CLIENT_ORIGIN=http://localhost:5173
# Demo mode returns sign-in codes in the HTTP response instead of emailing them,
# so local auth works without mail infra. NEVER enable in production (compose
# forces it false there).
DEMO_MODE=true

# --- Cloudflare Email Sending (sign-in codes + escalation emails) ---
# The FROM domain must be set up for sending in Cloudflare (note the mail. prefix,
# e.g. noreply@mail.example.com). Leave blank to disable (use DEMO_MODE locally).
CLOUDFLARE_EMAIL_ACCOUNT_ID=
CLOUDFLARE_EMAIL_API_TOKEN=
CLOUDFLARE_EMAIL_FROM_EMAIL=
CLOUDFLARE_EMAIL_FROM_NAME=Persistent

# --- Web Push (VAPID) ---
# Generate once with: npx web-push generate-vapid-keys
# If left blank, the API generates and persists a keypair on first boot.
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_SUBJECT=mailto:persistent@local

# --- Firebase Cloud Messaging (native Android push; optional) ---
FCM_SERVICE_ACCOUNT_FILE=
FCM_PROJECT_ID=

# Google login (optional). The WEB OAuth client id enables "Continue with Google"
# and is the audience for ID-token verification (also the native serverClientId).
# The Android client id only needs to exist in the Cloud project (package + SHA-1)
# for native sign-in; it isn't read by the code (kept here for reference).
GOOGLE_WEB_CLIENT_ID=
GOOGLE_ANDROID_CLIENT_ID=

# --- App-store review access (production only) ---
# Sign-in is passwordless, so an app-store reviewer can't receive the emailed
# one-time code. These let ONE designated account sign in with a fixed code, which
# is what goes in Google Play's "App access" form. Both must be set or the path
# doesn't exist (leave unset in dev — demo mode already prints codes there).
#
# Point it at a throwaway account holding demo data, never a real one, and rotate
# the code once a review concludes: it is a shared secret typed into a console.
# Minimum 12 characters, enforced at boot. See apps/api/src/lib/review-access.ts.
REVIEW_ACCOUNT_EMAIL=
REVIEW_ACCOUNT_CODE=

# --- Deploy target (only on the machine running `npm run deploy:prod`) ---
DEPLOY_SSH_HOST=user@server.example.com
DEPLOY_REPO_PATH=/home/user/persistent
DEPLOY_BRANCH=main

# --- Android release signing (only when building the APK locally) ---
# Same key as the GitHub Actions secrets so updates install over each other.
# The keystore file itself is gitignored; CI decodes it from ANDROID_KEYSTORE_BASE64.
ANDROID_KEYSTORE_FILE=apps/mobile/release.keystore
ANDROID_KEYSTORE_PASSWORD=
ANDROID_KEY_ALIAS=persistent
ANDROID_KEY_PASSWORD=
