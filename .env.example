# Copy to .env and fill in. Development is devcontainer-only: DATABASE_URL and
# API_PORT are injected by devcontainer.json, so an empty .env is fine there.
# Set the values below only for non-default overrides.

# --- Database ---
# The devcontainer's `db` service provides this; override only if needed.
DATABASE_URL=postgresql://postgres:postgres@db:5432/persistent?schema=public

# --- API ---
API_PORT=4000
# Comma-separated allowed browser origins (CORS + secure-cookie detection).
CLIENT_ORIGIN=http://localhost:5173

# Demo mode returns sign-in codes in the HTTP response instead of emailing them,
# so local auth works without mail infra. NEVER enable in production.
DEMO_MODE=true

# --- Cloudflare Email Sending (sign-in codes + escalation emails) ---
# Leave blank to keep email delivery disabled (use DEMO_MODE locally).
CLOUDFLARE_EMAIL_ACCOUNT_ID=
CLOUDFLARE_EMAIL_API_TOKEN=
CLOUDFLARE_EMAIL_FROM_EMAIL=
CLOUDFLARE_EMAIL_FROM_NAME=Persistent

# --- Web Push (VAPID) ---
# Generate once with: npx web-push generate-vapid-keys
# If left blank, the API generates and persists a keypair on first boot.
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_SUBJECT=mailto:persistent@local

# --- Firebase Cloud Messaging (native Android push; optional) ---
# Path to a Firebase service-account JSON, or leave blank to disable FCM.
FCM_SERVICE_ACCOUNT_FILE=
FCM_PROJECT_ID=
