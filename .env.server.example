# Production env for the SSH-Docker deploy. Copy to .env.server ON THE SERVER
# (next to compose.server.yml). Never commit the filled-in file.

# --- Postgres (compose `db` service) ---
POSTGRES_DB=persistent
POSTGRES_USER=postgres
POSTGRES_PASSWORD=change-me-strong

# --- App ---
# The public URL the app is served from (used for CORS + secure cookies).
CLIENT_ORIGIN=https://persistent.example.com

# --- Cloudflare Email Sending (sign-in codes + escalation emails) ---
CLOUDFLARE_EMAIL_ACCOUNT_ID=
CLOUDFLARE_EMAIL_API_TOKEN=
CLOUDFLARE_EMAIL_FROM_EMAIL=
CLOUDFLARE_EMAIL_FROM_NAME=Persistent

# --- Web Push (VAPID) ---
# Generate once with: npx web-push generate-vapid-keys
VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=
VAPID_SUBJECT=mailto:persistent@example.com

# --- Firebase Cloud Messaging (native Android push; optional) ---
FCM_SERVICE_ACCOUNT_FILE=
FCM_PROJECT_ID=

# --- Deploy target (read locally by scripts/deploy/deploy-over-ssh.mjs) ---
# These live in your LOCAL .env (not on the server).
DEPLOY_SSH_HOST=user@server.example.com
DEPLOY_REPO_PATH=/srv/persistent
DEPLOY_BRANCH=main
