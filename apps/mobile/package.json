{
  "name": "@persistent/mobile",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "Capacitor (Android) wrapper of the web app + the native alarm plugin.",
  "scripts": {
    "typecheck": "tsc --noEmit -p tsconfig.json",
    "gen:icons": "node scripts/gen-icons.mjs",
    "build:web": "npm --prefix ../.. run build --workspace @persistent/shared && npm --prefix ../.. run build --workspace @persistent/web",
    "add:android": "cap add android",
    "setup:android": "node scripts/setup-android.mjs",
    "sync": "cap sync android",
    "open:android": "cap open android",
    "assemble:android": "cd android && ./gradlew assembleDirectDebug",
    "assemble:release": "cd android && ./gradlew assembleDirectRelease",
    "bundle:play": "cd android && ./gradlew bundlePlayRelease",
    "prepare:android": "npm run build:web && npm run add:android && npm run setup:android && npm run sync",
    "verify:android": "npm run setup:android && cd android && ./gradlew --console=plain :app:compilePlayDebugKotlin :app:compilePlayDebugJavaWithJavac :app:compileDirectDebugKotlin :app:compileDirectDebugJavaWithJavac"
  },
  "dependencies": {
    "@capacitor/android": "^6.2.0",
    "@capacitor/app": "^6.0.2",
    "@capacitor/core": "^6.2.0",
    "@capacitor/preferences": "^6.0.3",
    "@capacitor/push-notifications": "^6.0.4"
  },
  "devDependencies": {
    "@capacitor/cli": "^6.2.0",
    "typescript": "^5.8.3"
  }
}
