<!--
  Merge these into the generated android/app/src/main/AndroidManifest.xml.
  Permissions go at the top level; the service/receivers/activity go inside
  <application>. See README.md.
-->

<!-- ===== permissions (top level, before <application>) ===== -->
<uses-permission android:name="android.permission.POST_NOTIFICATIONS" />
<uses-permission android:name="android.permission.SCHEDULE_EXACT_ALARM" />
<uses-permission android:name="android.permission.USE_EXACT_ALARM" />
<uses-permission android:name="android.permission.FOREGROUND_SERVICE" />
<uses-permission android:name="android.permission.FOREGROUND_SERVICE_SPECIAL_USE" />
<uses-permission android:name="android.permission.USE_FULL_SCREEN_INTENT" />
<uses-permission android:name="android.permission.WAKE_LOCK" />
<uses-permission android:name="android.permission.VIBRATE" />
<uses-permission android:name="android.permission.RECEIVE_BOOT_COMPLETED" />
<uses-permission android:name="android.permission.REQUEST_IGNORE_BATTERY_OPTIMIZATIONS" />
<!-- REQUEST_INSTALL_PACKAGES is deliberately NOT here: it belongs to the `direct`
     flavor only (flavor/direct/AndroidManifest.xml). Google Play forbids an app it
     distributes from updating itself, and that permission is the signal review
     looks for — it must never reach the `play` build. -->


<!-- androidx.car.app is minSdk 23 while the app floor is 22. Android Auto itself
     needs API 23+, and CarProjection.init is SDK-guarded, so overriding the library's
     minSdk here is safe (Gradle still injects the app's real minSdk). -->
<uses-sdk tools:overrideLibrary="androidx.car.app" />

<!-- ===== inside <application> ===== -->
<service
    android:name="ca.persistent.app.alarm.AlarmService"
    android:exported="false"
    android:foregroundServiceType="specialUse">
    <property
        android:name="android.app.PROPERTY_SPECIAL_USE_FGS_SUBTYPE"
        android:value="Reminder alarms that must fire and keep sounding until the user confirms completion." />
</service>

<activity
    android:name="ca.persistent.app.alarm.AlarmActivity"
    android:exported="false"
    android:showWhenLocked="true"
    android:turnScreenOn="true"
    android:excludeFromRecents="true"
    android:launchMode="singleInstance"
    android:theme="@android:style/Theme.Material.NoActionBar" />

<activity
    android:name="ca.persistent.app.alarm.SnoozePickerActivity"
    android:exported="false"
    android:showWhenLocked="true"
    android:turnScreenOn="true"
    android:excludeFromRecents="true"
    android:launchMode="singleInstance"
    android:theme="@android:style/Theme.Material.NoActionBar" />

<receiver
    android:name="ca.persistent.app.alarm.AlarmReceiver"
    android:exported="false" />

<receiver
    android:name="ca.persistent.app.alarm.BootReceiver"
    android:exported="true">
    <intent-filter>
        <action android:name="android.intent.action.BOOT_COMPLETED" />
    </intent-filter>
</receiver>

<!-- Our FCM receiver handles server pushes natively (acts even when the WebView is
     dead) and forwards to Capacitor's JS bridge via super(). Register it for the
     MESSAGING_EVENT and drop @capacitor/push-notifications' own service so Firebase
     dispatches to exactly one. (Requires xmlns:tools on <manifest>; setup-android
     adds it.) -->
<service
    android:name="ca.persistent.app.alarm.FcmService"
    android:exported="false">
    <intent-filter>
        <action android:name="com.google.firebase.MESSAGING_EVENT" />
    </intent-filter>
</service>
<service
    android:name="com.capacitorjs.plugins.pushnotifications.MessagingService"
    tools:node="remove" />

<!-- Declares that the app extends its notifications to Android Auto; points at
     res/xml/automotive_app_desc.xml (<uses name="notification"/>). Required for Auto
     to project our MessagingStyle reminder notifications. See docs/alarm-architecture.md. -->
<meta-data
    android:name="com.google.android.gms.car.application"
    android:resource="@xml/automotive_app_desc" />
